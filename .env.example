# ==========================================
# NEMESIS DASHBOARD CONFIGURATION
# ==========================================

# --- Environment & Server ---
# Application environment (development | production)
NODE_ENV=production

# The port the application will bind to
PORT=3000

# Allowed CORS origins (use commas for multiple origins, or * for all)
CORS_ORIGIN=*


# --- Data & Asset Paths ---
# Path to the primary SQLite database
SQLITE_PATH=data/dashboard.sqlite

# Directory containing the raw audit JSON datasets
AUDIT_DATASET_DIR=dataset

# Root directory holding the MapLibre GeoJSON structural data
GEO_ROOT_PATH=seed/geo
